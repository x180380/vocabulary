<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_background"
    android:fillViewport="true">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_margin="16dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="@color/color_surface">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Top row: progress + bookmark -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/tvProgress"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="13sp"
                    android:textColor="@color/color_text_secondary" />

                <TextView
                    android:id="@+id/tvBookmark"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="@string/bookmark"
                    android:textSize="12sp"
                    android:textColor="@color/color_text_secondary"
                    android:gravity="center_vertical"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:drawableStart="@drawable/ic_bookmark_outline"
                    android:drawablePadding="4dp"
                    android:background="@drawable/bg_bookmark_chip"
                    android:clickable="true"
                    android:focusable="true" />

            </LinearLayout>

            <!-- Tap-to-reveal placeholder -->
            <TextView
                android:id="@+id/tvTapToReveal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tap_to_reveal"
                android:textSize="16sp"
                android:textColor="@color/color_text_secondary"
                android:layout_gravity="center_horizontal"
                android:padding="12dp"
                android:layout_marginBottom="8dp" />

            <!-- English word -->
            <TextView
                android:id="@+id/tvEnglish"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="36sp"
                android:textColor="@color/color_on_surface"
                android:fontFamily="serif"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="8dp" />

            <!-- Phonetics -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="20dp">

                <!-- British pill -->
                <LinearLayout
                    android:id="@+id/llPhoneticBritish"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_phonetic_pill"
                    android:paddingStart="10dp"
                    android:paddingEnd="4dp"
                    android:paddingTop="5dp"
                    android:paddingBottom="5dp"
                    android:layout_marginEnd="10dp">

                    <TextView
                        android:id="@+id/tvPhoneticBritish"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="13sp"
                        android:textColor="@color/color_text_secondary" />

                    <ImageButton
                        android:id="@+id/btnPlayBritish"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_sound_wave"
                        android:background="@android:color/transparent"
                        android:padding="4dp"
                        android:layout_marginStart="2dp"
                        android:contentDescription="@string/play_british" />

                </LinearLayout>

                <!-- American pill -->
                <LinearLayout
                    android:id="@+id/llPhoneticAmerican"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_phonetic_pill"
                    android:paddingStart="10dp"
                    android:paddingEnd="4dp"
                    android:paddingTop="5dp"
                    android:paddingBottom="5dp">

                    <TextView
                        android:id="@+id/tvPhoneticAmerican"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="13sp"
                        android:textColor="@color/color_text_secondary" />

                    <ImageButton
                        android:id="@+id/btnPlayAmerican"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_sound_wave"
                        android:background="@android:color/transparent"
                        android:padding="4dp"
                        android:layout_marginStart="2dp"
                        android:contentDescription="@string/play_american" />

                </LinearLayout>

            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/color_divider"
                android:layout_marginBottom="16dp" />

            <!-- Definitions (rows added dynamically) -->
            <LinearLayout
                android:id="@+id/llDefinitions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="20dp" />

            <!-- Examples header -->
            <LinearLayout
                android:id="@+id/llExamplesHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp"
                android:visibility="gone">



                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/example_header"
                    android:textSize="14sp"
                    android:textColor="@color/color_text_secondary"
                    android:textStyle="bold"/>

            </LinearLayout>

            <!-- Examples (rows added dynamically) -->
            <LinearLayout
                android:id="@+id/llExamples"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</ScrollView>
