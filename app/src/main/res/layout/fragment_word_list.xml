<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_background">

    <LinearLayout
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/btnGroupView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="显示分组"
            android:textSize="14sp"
            android:textColor="@color/toolbar_icon"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true" />

        <Space
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />
        <TextView
            android:id="@+id/btnFilter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="书签"
            android:textSize="14sp"
            android:textColor="@color/toolbar_icon"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true" />
        <TextView
            android:id="@+id/btnSort"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="排序"
            android:textSize="14sp"
            android:textColor="@color/toolbar_icon"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true" />
        <TextView
            android:id="@+id/btnEdit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="编辑"
            android:textSize="14sp"
            android:textColor="@color/toolbar_icon"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

    <!-- Selected count (batch mode only) -->
    <TextView
        android:id="@+id/tvSelectedCount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:textSize="14sp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintStart_toStartOf="parent" />

    <Button
        android:id="@+id/btnSelectAll"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/action_select_all"
        android:textSize="12sp"
        android:visibility="gone"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvWords"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintBottom_toTopOf="@id/bottomBarNormal"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvEmpty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/empty_word_list"
        android:textSize="16sp"
        android:textColor="@color/color_text_secondary"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintBottom_toTopOf="@id/bottomBarNormal"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Normal bottom bar -->
    <LinearLayout
        android:id="@+id/bottomBarNormal"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:background="@color/color_surface"
        android:elevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <Button
            android:id="@+id/btnListenWords"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:text="@string/listen_words"
            android:textSize="13sp"
            android:textColor="@color/color_on_surface"
            style="@style/Widget.MaterialComponents.Button.TextButton" />

        <View android:layout_width="1dp" android:layout_height="match_parent"
            android:background="@color/color_divider" />

        <Button
            android:id="@+id/btnHideDefinition"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:text="@string/hide_definition"
            android:textSize="13sp"
            android:textColor="@color/color_on_surface"
            style="@style/Widget.MaterialComponents.Button.TextButton" />

        <View android:layout_width="1dp" android:layout_height="match_parent"
            android:background="@color/color_divider" />

        <Button
            android:id="@+id/btnCardStudy"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:text="@string/card_study"
            android:textSize="13sp"
            android:textColor="@color/color_on_surface"
            style="@style/Widget.MaterialComponents.Button.TextButton" />

    </LinearLayout>

    <!-- Batch mode bottom bar -->
    <LinearLayout
        android:id="@+id/bottomBarBatch"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:background="@color/color_surface"
        android:elevation="8dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent">

        <Button
            android:id="@+id/btnBatchTag"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:text="@string/action_tag"
            android:textSize="13sp"
            style="@style/Widget.MaterialComponents.Button.TextButton" />

        <View android:layout_width="1dp" android:layout_height="match_parent"
            android:background="@color/color_divider" />

        <Button
            android:id="@+id/btnBatchMoveTo"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:text="@string/action_move_to"
            android:textSize="13sp"
            style="@style/Widget.MaterialComponents.Button.TextButton" />

        <View android:layout_width="1dp" android:layout_height="match_parent"
            android:background="@color/color_divider" />

        <Button
            android:id="@+id/btnBatchDelete"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:text="@string/action_delete"
            android:textSize="13sp"
            android:textColor="@android:color/holo_red_dark"
            style="@style/Widget.MaterialComponents.Button.TextButton" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
