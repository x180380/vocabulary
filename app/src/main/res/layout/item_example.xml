<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_marginBottom="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tvExampleEnglish"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="14sp"
            android:textColor="@color/color_on_surface"
            android:textStyle="bold"
            android:lineSpacingMultiplier="1.3" />

        <ImageButton
            android:id="@+id/btnPlayExample"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_sound_wave"
            android:background="@drawable/bg_play_example"
            android:contentDescription="@string/play_word"
            android:padding="8dp"
            android:layout_marginStart="8dp" />

    </LinearLayout>

    <TextView
        android:id="@+id/tvExampleChinese"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="13sp"
        android:textColor="@color/color_text_secondary"
        android:lineSpacingMultiplier="1.3"
        android:layout_marginTop="4dp" />

</LinearLayout>
