<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/action_create"
        android:textSize="18sp"
        android:fontFamily="sans-serif-medium"
        android:layout_marginBottom="16dp" />

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/vocab_name_hint"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etVocabName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text"
            android:maxLines="1" />

    </com.google.android.material.textfield.TextInputLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="选择颜色"
        android:textSize="14sp"
        android:textColor="@color/color_text_secondary"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="8dp" />

    <com.google.android.material.chip.ChipGroup
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:singleSelection="true"
        android:layout_marginBottom="16dp">

        <com.google.android.material.chip.Chip
            android:id="@+id/colorChip0"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=" "
            app:chipBackgroundColor="@color/card_color_0"
            app:checkedIconVisible="true"
            style="@style/Widget.MaterialComponents.Chip.Filter" />

        <com.google.android.material.chip.Chip
            android:id="@+id/colorChip1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=" "
            app:chipBackgroundColor="@color/card_color_1"
            app:checkedIconVisible="true"
            style="@style/Widget.MaterialComponents.Chip.Filter" />

        <com.google.android.material.chip.Chip
            android:id="@+id/colorChip2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=" "
            app:chipBackgroundColor="@color/card_color_2"
            app:checkedIconVisible="true"
            style="@style/Widget.MaterialComponents.Chip.Filter" />

        <com.google.android.material.chip.Chip
            android:id="@+id/colorChip3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=" "
            app:chipBackgroundColor="@color/card_color_3"
            app:checkedIconVisible="true"
            style="@style/Widget.MaterialComponents.Chip.Filter" />

        <com.google.android.material.chip.Chip
            android:id="@+id/colorChip4"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=" "
            app:chipBackgroundColor="@color/card_color_4"
            app:checkedIconVisible="true"
            style="@style/Widget.MaterialComponents.Chip.Filter" />

        <com.google.android.material.chip.Chip
            android:id="@+id/colorChip5"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=" "
            app:chipBackgroundColor="@color/card_color_5"
            app:checkedIconVisible="true"
            style="@style/Widget.MaterialComponents.Chip.Filter" />

        <com.google.android.material.chip.Chip
            android:id="@+id/colorChip6"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=" "
            app:chipBackgroundColor="@color/card_color_6"
            app:checkedIconVisible="true"
            style="@style/Widget.MaterialComponents.Chip.Filter" />

        <com.google.android.material.chip.Chip
            android:id="@+id/colorChip7"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=" "
            app:chipBackgroundColor="@color/card_color_7"
            app:checkedIconVisible="true"
            style="@style/Widget.MaterialComponents.Chip.Filter" />

    </com.google.android.material.chip.ChipGroup>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCreate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/action_confirm" />

</LinearLayout>
